# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=personal_os_db
POSTGRES_USER=personal_os
POSTGRES_PASSWORD=change_me_in_production

# ─── Backend ─────────────────────────────────────────────────
SECRET_KEY=change_me_32_chars_minimum_secret_key
ENCRYPTION_KEY=change_me_32_byte_fernet_key_base64=  # generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENV=development  # development | production
ALLOWED_ORIGINS=http://localhost

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost
NEXTAUTH_SECRET=change_me_nextauth_secret_min_32_chars

# ─── AI Providers (optional — can also be set via Settings UI) ─
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Video Generation (optional) ─────────────────────────────
RUNWAY_API_KEY=

# ─── Internal URLs (do not change for local dev) ─────────────
DATABASE_URL=postgresql+psycopg://personal_os:change_me_in_production@db:5432/personal_os_db
NEXT_PUBLIC_API_URL=http://localhost
API_URL=http://backend:8000
